# Rust
/target
**/target
Cargo.lock.bak

# Package lock files (intentionally untracked per project policy)
Cargo.lock
package-lock.json
**/package-lock.json
yarn.lock
pnpm-lock.yaml

# Node / frontend
node_modules
dist
.vite
*.tsbuildinfo

# Tauri generated
app/main/src-tauri/gen
app/main/src-tauri/target
installer/src-tauri/gen
installer/src-tauri/target
installer/dist

# Installer payload (filled at packaging time)
installer/src-tauri/payload/*
!installer/src-tauri/payload/README.md

# Native libs / models (downloaded on demand, not committed)
app/main/src-tauri/lib/*.dll
app/main/src-tauri/lib/*.so
app/main/src-tauri/lib/*.dylib
*.ggml
*.bin
ggml-*.bin

# Sidecar binaries (bundled at build time, not committed)
app/main/src-tauri/binaries/

# Android signing secrets (provided via CI secrets, never committed)
*.jks
*.keystore
keystore.properties

# OS / editor
.DS_Store
Thumbs.db
*.log
.idea/
.vscode/*
!.vscode/extensions.json

# Python
__pycache__/
*.pyc
