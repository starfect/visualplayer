{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Minimal capability set for the main window (BLUEPRINT §17). Only the plugins the app actually uses are enabled. Custom app commands are not permission-gated.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-set-always-on-top",
    "core:window:allow-set-size",
    "core:window:allow-inner-size",
    "core:window:allow-scale-factor",
    "opener:default",
    "dialog:default",
    "fs:default",
    "os:default",
    "libmpv:default"
  ]
}
